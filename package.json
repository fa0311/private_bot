{
  "name": "private_bot",
  "version": "1.0.0",
  "description": "Next generation bot using @line/bot-sdk and discord.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:snap": "tsx watch src/snap.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:snap": "node dist/snap.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check src",
    "lint:fix": "biome check --fix src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.6.0",
    "async-mutex": "^0.5.0",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "discord.js": "^14.26.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "twitter-openapi-typescript": "^0.0.55",
    "twitter-openapi-typescript-generated": "^0.0.38",
    "webdav": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typed-emitter": "^2.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "bot",
    "line",
    "discord",
    "typescript",
    "esm"
  ],
  "author": "yuki",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0"
}
